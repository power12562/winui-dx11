<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WsiuEngine.Core.MainEntry.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WsiuEngine.Core.MainEntry"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:shapes="using:Microsoft.UI.Xaml.Shapes"
    mc:Ignorable="d"
    Title="WsiuEngine">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="300" MinWidth="200" />
        </Grid.ColumnDefinitions>
        
        <SwapChainPanel x:Name="SceneCanvas"
                        Grid.Column="0" />
        <controls:GridSplitter Grid.Column="1"
                               Width="1"
                               HorizontalAlignment="Stretch"
                               Cursor="SizeWestEast"/>
        <Border Grid.Column="2"
                Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0">
            <StackPanel Padding="20" Spacing="10">
                <TextBlock Text="Inspector"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>
                <Button Content="Test Button" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
